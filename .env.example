# Pass Navigay — variables d'environnement front (Vite)
# Copier ce fichier en `.env.local` (ignoré par git) et remplir les valeurs.
# Ce sont les SEULES variables réellement lues par le code front (import.meta.env.*).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_MAPS_KEY=

# --- NB ---
# Les secrets serveur (SUPABASE_SERVICE_ROLE_KEY, STRIPE_SECRET_KEY,
# STRIPE_WEBHOOK_SECRET, RESEND_API_KEY, APP_URL) ne vivent PAS ici :
# ils se configurent dans les Supabase Edge Functions (dashboard Supabase),
# pas dans le build Vite. Voir supabase/functions/.
